# Wonder Baboon — clean URLs on Apache/LiteSpeed (Hostinger shared hosting)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # One canonical host (API CORS + Razorpay are configured for wonderbaboon.com)
  RewriteCond %{HTTP_HOST} ^www\.wonderbaboon\.com$ [NC]
  RewriteRule ^ https://wonderbaboon.com%{REQUEST_URI} [R=301,L]

  # Legacy dashboard → Your trips (before generic .html redirects)
  RewriteRule ^user-dashboard\.html$ /upcoming-trips [R=301,L,NC]
  RewriteRule ^user-dashboard/?$ /upcoming-trips [R=301,L,NC]

  # External request: /page.html → /page (301, keeps bookmarks working)
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ %1 [R=301,L]

  # Internal: /page → page.html (address bar stays clean)
  RewriteRule ^upcoming-trips/?$ upcoming-trips.html [L,NC]
  RewriteRule ^previous-trips/?$ previous-trips.html [L,NC]
  # Travel Gallery (clean URL — no extra rule needed beyond this line)
  RewriteRule ^previous-adventures/?$ previous-adventures.html [L,NC]
  RewriteRule ^settings/?$ settings.html [L,NC]
  RewriteRule ^auth/?$ auth.html [L,NC]
  RewriteRule ^admin-dashboard/?$ admin-dashboard.html [L,NC]
  RewriteRule ^backpackers/?$ backpackers.html [L,NC]
  RewriteRule ^motorcycle-diaries/?$ motorcycle-diaries.html [L,NC]
  RewriteRule ^dolce-far-niente/?$ dolce-far-niente.html [L,NC]
  RewriteRule ^hikers/?$ hikers.html [L,NC]
</IfModule>

DirectoryIndex index.html

# Cache: HTML + version manifest always revalidate; assets use browser cache until ?v= changes.
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "^(version\.json|version-check\.js)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>
