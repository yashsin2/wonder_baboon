# Local development (default). For production set ENV=production and apply stricter vars below.
ENV=development
PORT=5051
HOST=0.0.0.0

MONGO_URI=your_mongodb_atlas_connection_string
JWT_SECRET=generate_a_long_random_string_for_production
JWT_EXPIRE_HOURS=12

ADMIN_USERNAME=wb_admin
# Dev default allowed only when ENV=development. Production: 12+ chars and NOT the dev default.
ADMIN_PASSWORD=WB_Admin@2026

# Development: defaults include localhost. Production (ENV=production): REQUIRED — list real https:// origins only.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Brute-force throttle for POST /api/auth/login and /api/auth/signup (per IP per route).
AUTH_RATE_LIMIT_MAX=25
AUTH_RATE_LIMIT_WINDOW_SECONDS=120

# SMTP — OTP emails (profile changes). Blank in dev logs OTP to console instead of sending.
# Gmail: use an App Password, not your normal password — https://support.google.com/accounts/answer/185833
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

OTP_TTL_SECONDS=600
OTP_RATE_LIMIT_SECONDS=60

LOG_LEVEL=INFO

# Production checklist (ENV=production):
# - JWT_SECRET: strong unique value
# - ADMIN_PASSWORD: 12+ characters, not WB_Admin@2026
# - CORS_ORIGINS: https://yourdomain.com (comma-separated, no stray localhost)
# - MONGO_URI + Atlas IP allowlist
# - SMTP_* if you use email OTP
#
# Split UI/API hosts: inject before your scripts:
#   <script>window.__WB_API_BASE__="https://api.yourdomain.com/api";</script>
#
# Frontend dev: cd frontend && npm start  (http://localhost:3000)
# Backend dev:  cd backend && source ../.venv/bin/activate && python main.py
